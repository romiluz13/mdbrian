{
	"name": "@mdbrian/memory-bridge",
	"version": "1.1.0",
	"description": "Mdbrian bridge: stable facade for the memory engine used by HTTP API and MCP",
	"type": "module",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/romiluz13/mdbrian.git",
		"directory": "packages/memory-bridge"
	},
	"author": "Rom Iluz",
	"keywords": [
		"mdbrian",
		"mongodb",
		"memory",
		"bridge"
	],
	"main": "./dist/mdbrian-bridge.js",
	"types": "./dist/mdbrian-bridge.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/mdbrian-bridge.d.ts",
			"default": "./dist/mdbrian-bridge.js"
		}
	},
	"scripts": {
		"build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
		"check-types": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
		"test": "vitest run"
	},
	"dependencies": {
		"@mdbrian/lib": "1.1.0",
		"@mdbrian/memory-engine": "1.1.0"
	},
	"devDependencies": {
		"@mdbrian/tools": "workspace:*",
		"typescript": "^5.8.0",
		"vitest": "^4.1.0"
	},
	"homepage": "https://github.com/romiluz13/mdbrian#readme",
	"bugs": {
		"url": "https://github.com/romiluz13/mdbrian/issues"
	}
}
