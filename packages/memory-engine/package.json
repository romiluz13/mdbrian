{
	"name": "@mdbrain/memory-engine",
	"version": "1.1.0",
	"description": "MongoDB-native memory engine: embeddings, graph, episodes, search, knowledge base, reasoning chains, novelty detection, consolidation, analytics",
	"type": "module",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/romiluz13/mdbrain.git",
		"directory": "packages/memory-engine"
	},
	"author": "Rom Iluz",
	"keywords": [
		"mdbrain",
		"mongodb",
		"memory",
		"retrieval",
		"agent-memory"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
		"check-types": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
		"test": "vitest run --exclude=src/**/*.e2e.test.ts",
		"test:e2e": "vitest run src/**/*.e2e.test.ts"
	},
	"dependencies": {
		"@mdbrain/lib": "1.1.0",
		"chokidar": "^4.0.3",
		"mongodb": "7.2.0"
	},
	"optionalDependencies": {
		"node-llama-cpp": ">=3.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"typescript": "^5.8.0",
		"vitest": "^4.1.0"
	},
	"homepage": "https://github.com/romiluz13/mdbrain#readme",
	"bugs": {
		"url": "https://github.com/romiluz13/mdbrain/issues"
	}
}
