{
	"name": "@mbrain/tools",
	"version": "1.1.0",
	"description": "AI SDK tool helpers for Mbrain (function-calling tools for search, add, profile, etc.)",
	"type": "module",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/romiluz13/mbrain.git",
		"directory": "packages/tools"
	},
	"author": "Rom Iluz",
	"keywords": [
		"mbrain",
		"tools",
		"ai-sdk",
		"memory",
		"mongodb"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./vercel": {
			"types": "./dist/vercel/index.d.ts",
			"default": "./dist/vercel/index.js"
		},
		"./openai": {
			"types": "./dist/openai/index.d.ts",
			"default": "./dist/openai/index.js"
		}
	},
	"scripts": {
		"build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
		"check-types": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
		"test": "vitest run"
	},
	"dependencies": {
		"@mbrain/client": "1.1.0",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"ai": "^5.0.0",
		"typescript": "^5.8.0",
		"vitest": "^4.1.0"
	},
	"peerDependencies": {
		"ai": ">=5.0.0"
	},
	"homepage": "https://github.com/romiluz13/mbrain#readme",
	"bugs": {
		"url": "https://github.com/romiluz13/mbrain/issues"
	}
}
