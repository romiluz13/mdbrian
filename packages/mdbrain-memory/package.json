{
	"name": "@mdbrain/memory",
	"version": "1.1.0",
	"description": "Mdbrain memory: published re-export surface for the memory engine and bridge",
	"type": "module",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/romiluz13/mdbrain.git",
		"directory": "packages/mdbrain-memory"
	},
	"author": "Rom Iluz",
	"keywords": [
		"mdbrain",
		"memory",
		"mongodb",
		"agent-memory"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
		"check-types": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@mdbrain/memory-engine": "1.1.0",
		"@mdbrain/memory-bridge": "1.1.0"
	},
	"devDependencies": {
		"typescript": "^5.8.0"
	},
	"homepage": "https://github.com/romiluz13/mdbrain#readme",
	"bugs": {
		"url": "https://github.com/romiluz13/mdbrain/issues"
	}
}
