{
	"name": "@mbrain/lib",
	"version": "1.1.0",
	"description": "Shared types and utilities for Mbrain packages",
	"type": "module",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/romiluz13/mbrain.git",
		"directory": "packages/lib"
	},
	"author": "Rom Iluz",
	"keywords": [
		"mbrain",
		"runtime",
		"types",
		"utilities"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"default": "./dist/types.js"
		},
		"./types/memory": {
			"types": "./dist/types.memory.d.ts",
			"default": "./dist/types.memory.js"
		}
	},
	"scripts": {
		"build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
		"check-types": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json"
	},
	"devDependencies": {
		"typescript": "^5.8.0"
	},
	"homepage": "https://github.com/romiluz13/mbrain#readme",
	"bugs": {
		"url": "https://github.com/romiluz13/mbrain/issues"
	}
}
