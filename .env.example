# Memongo local development example

# MongoDB
MEMONGO_MONGODB_URI="mongodb://127.0.0.1:27017/?directConnection=true"

# HTTP API
MEMONGO_API_HOST="127.0.0.1"
MEMONGO_API_PORT="3847"
MEMONGO_API_KEY="local-dev-secret"

# Memory defaults
MEMONGO_AGENT_ID="main"
MEMONGO_MONGODB_RECALL_PROFILE="balanced"
MEMONGO_MONGODB_COLLECTION_PREFIX=""

# Logging (debug | info | warn | error; default info)
MEMONGO_LOG_LEVEL="info"

# Atlas Local Preview / MongoDB auto-embed
# Use a MongoDB Atlas Model API key with the al-... prefix.
# Specific sub-keys take priority over the generic VOYAGE_API_KEY.
VOYAGE_API_KEY=""
VOYAGE_API_INDEXING_KEY=""
VOYAGE_API_QUERY_KEY=""
VOYAGE_RERANK_API_KEY=""

# Optional LLM enrichment and real-agent smoke tests.
# OpenAI-compatible providers default to Authorization: Bearer.
MEMONGO_ENRICHMENT_API_KEY=""
MEMONGO_ENRICHMENT_BASE_URL="https://api.openai.com/v1"
MEMONGO_ENRICHMENT_MODEL="gpt-4o-mini"
MEMONGO_ENRICHMENT_AUTH_STYLE="authorization-bearer"
MEMONGO_ENRICHMENT_TOKEN_PARAM="max_tokens"

MEMONGO_LLM_API_KEY=""
MEMONGO_LLM_BASE_URL="https://api.openai.com/v1"
MEMONGO_LLM_MODEL="gpt-4o-mini"
MEMONGO_LLM_AUTH_STYLE="authorization-bearer"
MEMONGO_LLM_TOKEN_PARAM="max_tokens"

# Scoped API keys (JSON array). Optional; overrides MEMONGO_API_KEY per agent.
# Example: [{"token":"sk-agent1","agentIds":["agent-1"]}]
MEMONGO_API_SCOPED_KEYS=""
