# Mbrain local development example

# MongoDB
MBRAIN_MONGODB_URI="mongodb://127.0.0.1:27017/?directConnection=true"

# HTTP API
MBRAIN_API_HOST="127.0.0.1"
MBRAIN_API_PORT="3847"
MBRAIN_API_KEY="local-dev-secret"

# Memory defaults
MBRAIN_AGENT_ID="main"
MBRAIN_MONGODB_RECALL_PROFILE="balanced"
MBRAIN_MONGODB_COLLECTION_PREFIX=""

# Logging (debug | info | warn | error; default info)
MBRAIN_LOG_LEVEL="info"

# Atlas Local Preview / MongoDB auto-embed
# Use a MongoDB Atlas Model API key with the al-... prefix.
# Specific sub-keys take priority over the generic VOYAGE_API_KEY.
VOYAGE_API_KEY=""
VOYAGE_API_INDEXING_KEY=""
VOYAGE_API_QUERY_KEY=""
VOYAGE_RERANK_API_KEY=""

# Optional LLM enrichment and real-agent smoke tests.
# OpenAI-compatible providers default to Authorization: Bearer.
MBRAIN_ENRICHMENT_API_KEY=""
MBRAIN_ENRICHMENT_BASE_URL="https://api.openai.com/v1"
MBRAIN_ENRICHMENT_MODEL="gpt-4o-mini"
MBRAIN_ENRICHMENT_AUTH_STYLE="authorization-bearer"
MBRAIN_ENRICHMENT_TOKEN_PARAM="max_tokens"

MBRAIN_LLM_API_KEY=""
MBRAIN_LLM_BASE_URL="https://api.openai.com/v1"
MBRAIN_LLM_MODEL="gpt-4o-mini"
MBRAIN_LLM_AUTH_STYLE="authorization-bearer"
MBRAIN_LLM_TOKEN_PARAM="max_tokens"

# Scoped API keys (JSON array). Optional; overrides MBRAIN_API_KEY per agent.
# Example: [{"token":"sk-agent1","agentIds":["agent-1"]}]
MBRAIN_API_SCOPED_KEYS=""
