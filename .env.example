# Mdbrian local development example

# MongoDB
MDBRAIN_MONGODB_URI="mongodb://127.0.0.1:27017/?directConnection=true"

# HTTP API
MDBRAIN_API_HOST="127.0.0.1"
MDBRAIN_API_PORT="3847"
MDBRAIN_API_KEY="local-dev-secret"

# Memory defaults
MDBRAIN_AGENT_ID="main"
MDBRAIN_MONGODB_RECALL_PROFILE="balanced"
MDBRAIN_MONGODB_COLLECTION_PREFIX=""

# Logging (debug | info | warn | error; default info)
MDBRAIN_LOG_LEVEL="info"

# Atlas Local Preview / MongoDB auto-embed
# Use a MongoDB Atlas Model API key with the al-... prefix.
# Specific sub-keys take priority over the generic VOYAGE_API_KEY.
VOYAGE_API_KEY=""
VOYAGE_API_INDEXING_KEY=""
VOYAGE_API_QUERY_KEY=""
VOYAGE_RERANK_API_KEY=""

# Optional LLM enrichment and real-agent smoke tests.
# OpenAI-compatible providers default to Authorization: Bearer.
MDBRAIN_ENRICHMENT_API_KEY=""
MDBRAIN_ENRICHMENT_BASE_URL="https://api.openai.com/v1"
MDBRAIN_ENRICHMENT_MODEL="gpt-4o-mini"
MDBRAIN_ENRICHMENT_AUTH_STYLE="authorization-bearer"
MDBRAIN_ENRICHMENT_TOKEN_PARAM="max_tokens"

MDBRAIN_LLM_API_KEY=""
MDBRAIN_LLM_BASE_URL="https://api.openai.com/v1"
MDBRAIN_LLM_MODEL="gpt-4o-mini"
MDBRAIN_LLM_AUTH_STYLE="authorization-bearer"
MDBRAIN_LLM_TOKEN_PARAM="max_tokens"

# Scoped API keys (JSON array). Optional; overrides MDBRAIN_API_KEY per agent.
# Example: [{"token":"sk-agent1","agentIds":["agent-1"]}]
MDBRAIN_API_SCOPED_KEYS=""
